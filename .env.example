# ── App Identity ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ID=chris-auto-shine
NEXT_PUBLIC_SITE_URL=https://chrisautoshine.vercel.app
NEXT_PUBLIC_SITE_NAME=Chris Auto Shine

# ── Supabase ────────────────────────────────────────────────────────────────────
# This project uses the shared Dannflow Supabase project.
# See docs/SUPABASE_PLAN.md for setup instructions.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Rate Limiting (Optional — Upstash Redis) ───────────────────────────────────
# Leave blank to skip rate limiting (fails open — allows all requests)
# Sign up at upstash.com for a free Redis DB
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── EmailJS (Contact Form) ──────────────────────────────────────────────────────
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_AUTO_REPLY_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

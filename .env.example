# ── App Identity (tenant namespace — UNIQUE per project) ───────────────────────
# NEXT_PUBLIC_APP_ID is used by the service layer (.eq('app_id', ...))
# APP_ID is the server-side equivalent used to set the postgres app.id session var for RLS
NEXT_PUBLIC_APP_ID=chris-auto-shine
APP_ID=chris-auto-shine
NEXT_PUBLIC_SITE_URL=https://chrisautoshine.vercel.app
NEXT_PUBLIC_SITE_NAME=Chris Auto Shine

# ── Supabase (SHARED — same credentials as business-template) ───────────────────
# chris-auto-shine is a TENANT of the shared Dannflow Supabase project.
# Use the EXACT SAME URL and keys as the business-template project.
# Data is isolated by app_id = 'chris-auto-shine' at the service + RLS layer.
# Get these from: Supabase Dashboard > Project Settings > Data API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Rate Limiting (Optional — Upstash Redis) ───────────────────────────────────
# Leave blank to skip rate limiting (fails open — allows all requests)
# Sign up at upstash.com for a free Redis DB
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── EmailJS (Contact Form) ──────────────────────────────────────────────────────
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_AUTO_REPLY_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
